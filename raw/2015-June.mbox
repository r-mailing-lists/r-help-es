Un opción más elegante:

DES = function(x)
  {
	res=NA
	if(is.numeric(x)) res=mean(x)
	else if(is.factor(x))
        {
			res <- as.data.frame(table(x))
			res <- transform(res, cumFreq = cumsum(Freq), relative = prop.table(Freq))
        }
	return(res)	
  }

