## Ejemplo html2
source("R2HTML2.R")

html2.init() # Iniciar con los valores por defecto
# Alternativamente p.e. html2.init('Resultados', css="R2HTML.css", logo="../RHtmlUdcLogo2.gif")

html2.title() # Titulo por defecto
res <- summary(x <- rnorm(100))
html2(res) # Resultado con subtÝtulo por defecto
plot(x)
html2.graph() # Grßfico con subtÝtulo por defecto
# NOTA: actualmente guarda tambiÚn una copia del grßfico en formato pdf en el subdirectorio del informe
html2.title('Anßlisis de x')
hist(x)
html2.graph('Histograma de x')
html2(t.test(x), 'Test-t de x')
html2.title("Cuidado con 'source' junto a 'html2()'")
HTML.title("Utilizar 'html2()' despuÚs de evaluar interactivamente")   # Compatible con 'R2HTML'
HTML("DeberÝa generar el resultado anterior:")
t.test(x)
html2()

#html2.png()
#hist(x)
#dev.off()

html2.exit() # HTMLEndFile()

