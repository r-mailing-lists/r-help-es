gridsizes <- function(n){
  a <- 1:sqrt(n)
  a <- a[n %% a == 0]

  if(length(a) == 0)
    stop("No se ha encontrado ninguna opción")

  a <- a[length(a)]
  c(a, n / a)
}

gridsizes(50)


gridsizes.alt <- function(n, c1, c2){
  a <- 1:(n/2)
  a <- a[n %% a == 0]
  a <- a[c1 %% a == 0]

  b <- n / a
  b <- b[c2 %% b == 0]

  if(length(b) == 0)
    stop("No se ha encontrado ninguna opción")

  idx <- which.max(abs(b - n / b))

  c(n / b[idx], b[idx])
}


gridsizes.alt(100, 25, 4)


