AquÚ, una pequeþa ilustraciµn con la funciµn ellipse() del paquete "car"

require(car)
x=c(5,2,3);y=c(2,4,3) #coord. centros
centros=matrix(c(x,y),3,2)
desv.x=c(.5,.8,.3);desv.y=c(.2,.4,.5) #desviaciones
desv=matrix(c(desv.x,desv.y),3,2)
escala=1
plot(centros,type="n",xlab="Temperatura",ylab="Precipitaciones",xlim=c 
(1,6),ylim=c(1,6))
for(i in 1:3) ellipse(centros[i,], diag(desv[i,]),  
escala,col="grey",center.pch=(48+i),center.cex=2)

