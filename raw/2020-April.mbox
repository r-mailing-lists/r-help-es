precios <- read.table(
  text ="Producto PaÚs Precio Unidad Peso
A AR 10 kg 12
B BR 210 lb 0,5
C UY 3,5 kg 90
A BR 3 kg 3
C CO 345 lb 7,6
A CO 1200 gr 23000",
  dec = ",", header = TRUE,
  stringsAsFactors = FALSE)

tipos <- read.table(
  text ="PaÚs TC
AR 12
BR 1,8
CO 45
UY 0,5",
  dec = ",", header = TRUE,
  stringsAsFactors = FALSE)

ratios <- read.table(
  text = "Unidad Ratio
kg 1000
lb 0,89
gr 1",
  dec = ",", header = TRUE,
  stringsAsFactors = FALSE)

library(dplyr)
precios %>% 
  inner_join(tipos) %>% 
  inner_join(ratios) %>% 
  mutate(Precio2 = Precio*TC/(Peso/Ratio))

