O así, también:


file="datos.txt"

for (i in 1:length(d)){
     di<-d[[i]]
     nc<-ncol(di)

       write(paste("Pedigree: ",  unique(di$ped)),file=file, append=TRUE)
       write(colnames(di),file=file, sep = "\t", ncolumns=nc, append=TRUE)
       write(t(as.matrix(di)), file=file, sep = "\t", ncolumns=nc, 
append=TRUE)
}


Saludos,





