Hola,

Esta es una forma de hacerlo con la librería "purrr":

#-----------------------
> library(purrr)
> x <- list(20, 25, 35)
> p <- list(2, 3, 5)
> res_out <- unlist(seq_along(x) %>%
+      map( ~seq(x[[.]], length.out = p[[.]], by=1) ))
> res_out
 [1] 20 21 25 26 27 35 36 37 38 39
#-----------------------

