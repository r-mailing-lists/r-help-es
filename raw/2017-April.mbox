Hola,

Esta es una forma:

#---------------

df <- data.frame(
                   a = rnorm(10),
                   b = rnorm(10),
                   c = rnorm(10)
                )

my_nam <- names(df)
my_new_nam <- ifelse(my_nam == "a", "nuevo_a", ifelse(my_nam == "b",
"nuevo_b", ifelse( my_nam == "c", "nuevo_c", my_nam )) )
my_new_nam
names(df) <- my_new_nam

#---------------

Saludos,
