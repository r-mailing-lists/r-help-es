Podrías probar con algo así:

require(lubridate)

diasMes = function(limites){
  inicio = as.Date(limites[1], format = "%Y-%m-%d")
  fin = as.Date(limites[2], format = "%Y-%m-%d")
  secuencia = seq(inicio, fin, "days")
  meses = month(secuencia)
  return(table(meses))
}

apply(df, 1, diasMes)

