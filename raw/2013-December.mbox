eu60.pca <- PCA(eu60, quali.sup=19)

eu60.data <- cbind.data.frame(eu60[,19], eu60.pca$ind$coord)

eu60.ellipse <- coord.ellipse(eu60.data, bary=TRUE)

plot.PCA(ellipse=eu60.ellipse, cex=0.8)

 

 

