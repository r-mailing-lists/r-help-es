Manuel

ggplot(legend=FALSE)+
  geom_point(data=NCDS,aes(x=lon,y=lat,color= PA),shape=15,size=1) +
  scale_color_manual(values=c("white","grey70"))+
  geom_path(data=map_data('world'), aes(x=long, y=lat,group=group))

ggplot(legend=FALSE)+
