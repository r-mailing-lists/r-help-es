Hola Juan,

SÚ, te recomiendo que uses la librerÚa "ggeasy" que simplifica mucho estas modificaciones, mejor que trabajar directamente con "ggplot".
SerÚa asÚ:

#-------------
library(ggeasy)

ggplot(data = AîOS, aes(x = VARIEDAD, y = rAUDPCor, colour = ANO,
                         group = ANO)) +
  stat_summary(fun = mean, geom = "point") +
  stat_summary(fun = mean, geom = "line") +
  labs(y  =  'mean rAUDPCor') +
  labs(x  =  'Variety') +
  theme_bw() +
easy_rotate_x_labels( angle = 90)

#------------


