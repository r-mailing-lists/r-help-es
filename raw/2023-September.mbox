>  
> #-------------
> library(ggeasy)
>  
> ggplot(data = AŃOS, aes(x = VARIEDAD, y = rAUDPCor, colour = ANO,
>                          group = ANO)) +
>   stat_summary(fun = mean, geom = "point") +
>   stat_summary(fun = mean, geom = "line") +
>   labs(y  =  'mean rAUDPCor') +
>   labs(x  =  'Variety') +
