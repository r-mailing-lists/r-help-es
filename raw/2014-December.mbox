Es semejante

library(sqldf)
x <- 1:3
y <- 4:6
d <- data.frame(x, y)
d$z <- with(d, paste0(x, ":", y, "-ABC"))
d

sqldf("select x, y, x || ':' || y || '-ABC' from d")


