>      res_val %<>%
>        mutate.(res_tot = sum(res_sum)) %>%
>        mutate.(res_per = res_sum/res_tot) %>%
>        select.(res_per)
>      dt_comp <- cbind(dt_comp, res_val)
>    }
>   return(dt_comp)
> }
>
> #------ Process
> dt_comp <- data.table()
> for (i in 1:ncol(comb_tmp)) {
