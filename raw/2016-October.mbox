        apply(X = dat,  MARGIN = 1, FUN =
                 function(x){
                   return(   min(  which( !is.na(x)  ),  na.rm = TRUE ) )
                 }
        )
    },
    times = N, unit = "s")

tabla %>%  print
beepr::beep(3)

