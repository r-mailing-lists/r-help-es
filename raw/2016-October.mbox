#matrices mejor que dfs
tmp <- as.matrix(dat)

# min implementado a mano:
my.cols <- rep(ncol(tmp), nrow(tmp))
for (i in (ncol(tmp) - 1):1)
  my.cols[!is.na(tmp[,i])] <- i

# al canasto:
my.values <- tmp[cbind(1:nrow(tmp), my.cols)]


