Hola,

Aquí, tienes otra forma que es bastante sencilla de leer/entender...


Lines <- "   GRUPO ORDEN    CLASE
1      A     1 CLASE-01
2      A     2 CLASE-02
3      A     5 CLASE-03
4      B     1 CLASE-01
5      B     2 CLASE-02
6      B     5 CLASE-03
7      B     7 CLASE-04
8      C     2 CLASE-02
9      C     5 CLASE-03
10     C     7 CLASE-04
11     D     5 CLASE-03
12     D     7 CLASE-04
13     E     1 CLASE-06
14     F     2 CLASE-02
15     F     5 CLASE-03
16     F     7 CLASE-05
17     G     1 CLASE-07"

library(dplyr)
DF %>%
  group_by(GRUPO) %>%
  select(GRUPO, ORDEN, CLASE) %>%
  filter(ORDEN == min(ORDEN))


