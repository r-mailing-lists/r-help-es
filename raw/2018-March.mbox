13     E     1 CLASE-06
14     F     2 CLASE-02
15     F     5 CLASE-03
16     F     7 CLASE-05
17     G     1 CLASE-07"

DF <- read.table(textConnection(Lines), header = TRUE, as.is = TRUE)

library(data.table)
DT <- as.data.table(DF)
DT[, .SD[1], by="GRUPO"]

