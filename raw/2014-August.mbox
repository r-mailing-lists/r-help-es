 if (dat[n,1] == "NA")
 if (dat[n,1] == "")
 if (dat[n,1] == "<NA>")

y con lo mismo pero %in% en lugar de ==


  # rellenar los espacios vacios de la identificacion

  dat[,1] <- as.character(dat[,1])
  n <- 2
  for (n in 2:nrow(dat))
  {
    if (dat[n,1] %in% "NA")
      {
	dat[n,1] <- dat[n-1,1]
	dat[n,2] <- dat[n-1,2]
	dat[n,3] <- dat[n-1,3]
	dat[n,4] <- dat[n-1,4]
      }
      n <- n + 1
  }


