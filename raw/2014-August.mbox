        tmp <- read.csv(filenames[i], header=FALSE, sep="\t")
        rowsgod <- tmp[grep("16|18", tmp[,7]),]
        namestmp <- rep(filenames[i], dim(rowsgod)[1])
        dattmp <- cbind.data.frame(namestmp, rowsgod)
        dat <- rbind.data.frame(dat,dattmp)

