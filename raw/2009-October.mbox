Prueba lo siguiente:

#Suponiendo que M1 y M2 son matrices de misma dimensión

M.merge=NULL
for(i in 1:dim(M1)[1]) {
	M.merge=rbind(M.merge,M1[i,],M2[i,])
	}
Data=data.frame(M.merge)
