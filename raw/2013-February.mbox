> Creo que esto Funciona:
>
> ## --------------------------------
> x <- '1,2,"algo;todo"; 3,"cosa; mala"; 4,2,3,7;'
> m <- gregexpr('"[^"]*"', x)
> blanks <- function(n) {
>   vapply(Map(rep.int, rep.int(" ", length(n)), n, USE.NAMES = FALSE),
>          paste, "", collapse = "")
> }
> s <- x
> regmatches(s, m) <- Map(blanks, lapply(regmatches(s, m), nchar))
> m <- gregexpr("; *", s)
> cbind(regmatches(x, m, invert = TRUE)[[1]])
