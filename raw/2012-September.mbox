El paquete gplots creo te puede servir. Otros paquetes que pueden
ayudarte en hacer de una tabla un gráfico son Hmisc,
PerformanceAnalytics, gridExtra y dprint. Pero para  lo que pregutas
me inclino por la función textplot.

library(gplots)
require(graphics)
## Annette Dobson (1990) "An Introduction to Generalized Linear Models".
## Page 9: Plant Weight Data.
ctl <- c(4.17,5.58,5.18,6.11,4.50,4.61,5.17,4.53,5.33,5.14)
trt <- c(4.81,4.17,4.41,3.59,5.87,3.83,6.03,4.89,4.32,4.69)
group <- gl(2,10,20, labels=c("Ctl","Trt"))
weight <- c(ctl, trt)
lm.D9 <- lm(weight ~ group)
lm.D90 <- lm(weight ~ group - 1) # omitting intercept

anova(lm.D9)
summary(lm.D90)

par(mfrow = c(3,2))
plot(lm.D9, las = 1)      # Residuals, Fitted, ...
# Hasta aquí el ejemplo de la función lm, lo usé para obtener un summary
# A continuación las tablas
textplot(capture.output(summary(lm.D90))[c(-1, -2, -3, -4, -8, -13,
-15, -19)], halign="left", valign="bottom", cex=1)
textplot(capture.output(anova(lm.D90)), halign="left", valign="bottom", cex=1)

Daniel.


