        new_df$hmyears[i] <- new_df$hmyears[max(coin)] + 1
      } else {                            #Tres
        new_df$ID[i] <- df$ID[i]
        new_df$Year[i] <- df$Year[i]
        new_df$newID[i] <- max(new_df$newID) + 1
        new_df$hmyears[i] <- 1
      } #Tres

    } #Dos
  } #Uno
