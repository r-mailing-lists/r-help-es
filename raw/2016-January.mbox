Con la librería lubridate es muy fácil. El siguiente código lo hace:
Library(lubridate)
datos <- read.csv("clima.csv")    # leo los datos
datosS$CST <- as.Date(datos$CST)  # convierto en fecha la variable CST de los datos

# Si quiero crear una nueva variable en datos con el número de semana del ańo (week() es una función de lubridate)
datos$SEMANA <-  week(datos$CST)
# Si quiero crear una nueva variable con el ańo (year() es también una función de lubridate)
datos$ANYO <-  year(datos$CST)
# Y si quieres una variable carácter del tipo "50-2014" o "05-2014" (semana con dos dígitos , guion y ańo) está  esta contestación de Stackoverflow
# http://stackoverflow.com/questions/21484953/find-month-from-week-numbers-using-lubridate

datos$SEMANA_ANYO <- sprintf("%02d-%d", week(datos$CST), year(datos$CST))



